PORT=8080

# Store: use memory for local development, firestore for production.
STORE_DRIVER=memory
GCP_PROJECT_ID=
GOOGLE_CLOUD_PROJECT=
FIRESTORE_COLLECTION=sms_otp_challenges

# Internal API and cryptographic secrets. Replace with long random values.
SMS_OTP_SERVICE_API_TOKEN=replace-with-long-random-service-token
SMS_OTP_SECRET=replace-with-at-least-32-random-bytes
SMS_MFA_SESSION_SECRET=replace-with-at-least-32-random-bytes
OTP_MESSAGE_TEMPLATE=Your verification code is {{CODE}}. It expires in {{MINUTES}} minutes.

# Provider: twilio or amazon_sns.
SMS_PROVIDER=twilio

# Twilio Messaging Service.
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_MESSAGING_SERVICE_SID=

# Amazon Simple Notification Service.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_SNS_SMS_TYPE=Transactional
AWS_SNS_SENDER_ID=
